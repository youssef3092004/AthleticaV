// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TrainerClientStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum WorkoutLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MealTime {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum MealPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProgressMetricType {
  WEIGHT
  BODY_FAT
  MUSCLE
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
}

enum TransactionStatus {
  PENDING
  PAID
  FAILED
}

enum PayoutStatus {
  REQUESTED
  PAID
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  phone        String   @unique
  profileImage String   @default("https://cdn.pixabay.com/photo/2020/07/01/12/58/icon-5359553_640.png")
  email        String?  @unique
  password     String
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRoles              UserRole[]
  trainerProfile         TrainerProfile?
  trainerClientsAsCoach  TrainerClient[]   @relation("TrainerClientsTrainer")
  trainerClientsAsUser   TrainerClient[]   @relation("TrainerClientsClient")
  workoutTemplates       WorkoutTemplate[]
  workoutsAsClient       Workout[]         @relation("WorkoutClient")
  workoutsAsTrainer      Workout[]         @relation("WorkoutTrainer")
  mealTemplates          MealTemplate[]
  mealPlansAsClient      MealPlan[]        @relation("MealPlanClient")
  mealPlansAsTrainer     MealPlan[]        @relation("MealPlanTrainer")
  progressMetrics        ProgressMetric[]
  conversationsAsTrainer Conversation[]    @relation("ConversationTrainer")
  conversationsAsClient  Conversation[]    @relation("ConversationClient")
  sentMessages           Message[]         @relation("MessageSender")
  transactionsAsClient   Transaction[]     @relation("TransactionClient")
  transactionsAsTrainer  Transaction[]     @relation("TransactionTrainer")
  trainerWallet          TrainerWallet?
  payouts                Payout[]
  activityLogs           ActivityLog[]
  exercises              Exercise[]
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id  String @id @default(uuid()) @db.Uuid
  key String @unique

  rolePermissions RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model TrainerProfile {
  id              String  @id @default(uuid()) @db.Uuid
  trainerId       String  @unique @db.Uuid
  bio             String?
  certifications  String?
  yearsExperience Int?
  rating          Float?  @default(0)
  isVerified      Boolean @default(false)

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model TrainerClient {
  id        String              @id @default(uuid()) @db.Uuid
  trainerId String              @db.Uuid
  clientId  String              @db.Uuid
  status    TrainerClientStatus @default(ACTIVE)
  startedAt DateTime            @default(now())

  trainer User @relation("TrainerClientsTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  client  User @relation("TrainerClientsClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([trainerId, clientId])
}

enum Category {
  CHEST
  BACK
  LEGS
  ARMS
  SHOULDERS
  CORE
  CARDIO
}

model Exercise {
  id        String @id @default(uuid()) @db.Uuid
  trainerId String @db.Uuid

  name         String
  category     Category
  videoUrl     String
  instructions String?
  createdAt    DateTime @default(now())

  trainer      User          @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  workoutItems WorkoutItem[]
}

model WorkoutTemplate {
  id        String       @id @default(uuid()) @db.Uuid
  trainerId String       @db.Uuid
  title     String
  level     WorkoutLevel @default(BEGINNER)
  createdAt DateTime     @default(now())

  trainer  User      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  workouts Workout[]
}

model Workout {
  id                String   @id @default(uuid()) @db.Uuid
  workoutTemplateId String?  @db.Uuid
  clientId          String   @db.Uuid
  trainerId         String   @db.Uuid
  startDate         DateTime @db.Date
  endDate           DateTime @db.Date

  workoutTemplate WorkoutTemplate? @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  client          User             @relation("WorkoutClient", fields: [clientId], references: [id], onDelete: Cascade)
  trainer         User             @relation("WorkoutTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  items           WorkoutItem[]
}

model WorkoutItem {
  id         String @id @default(uuid()) @db.Uuid
  workoutId  String @db.Uuid
  exerciseId String @db.Uuid

  sets        Int
  reps        Int
  restSeconds Int

  order Int // Order of the exercise in the workout 0 1 2 3 

  notes String?
  tempo String?
  rir   Int?
  rpe   Float?

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId])
}

model Food {
  id        String @id @default(uuid()) @db.Uuid
  name      String
  baseGrams Float // ALWAYS normalized (e.g. 100g)

  calories   Float
  protein    Float
  carbs      Float
  fat        Float
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  portions          FoodPortion[]
  mealPlanItems     MealPlanItem[]
  mealTemplateItems MealTemplateItem[]

  @@index([name])
  @@index([name, baseGrams])
  @@index([isArchived])
}

model FoodPortion {
  id     String @id @default(uuid()) @db.Uuid
  foodId String @db.Uuid
  label  String // "1 cup", "1 piece"
  grams  Float // REAL value

  food              Food               @relation(fields: [foodId], references: [id], onDelete: Cascade)
  mealPlanItems     MealPlanItem[]
  mealTemplateItems MealTemplateItem[]

  @@unique([foodId, label])
  @@unique([id, foodId])
  @@index([foodId])
}

model MealTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  trainerId   String   @db.Uuid
  title       String
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainer   User              @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  days      MealTemplateDay[]
  mealPlans MealPlan[]        @relation("MealPlanSourceTemplate")

  @@index([trainerId])
  @@index([trainerId, isArchived])
}

model MealTemplateDay {
  id             String   @id @default(uuid()) @db.Uuid
  mealTemplateId String   @db.Uuid
  dayIndex       Int
  createdAt      DateTime @default(now())

  template MealTemplate       @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  items    MealTemplateItem[]

  @@unique([mealTemplateId, dayIndex])
  @@index([mealTemplateId])
}

model MealTemplateItem {
  id        String   @id @default(uuid()) @db.Uuid
  dayId     String   @db.Uuid
  foodId    String   @db.Uuid
  portionId String   @db.Uuid
  quantity  Float    @default(1)
  mealTime  MealTime
  sortOrder Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  day     MealTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  food    Food            @relation(fields: [foodId], references: [id], onDelete: Restrict)
  portion FoodPortion     @relation(fields: [portionId, foodId], references: [id, foodId], onDelete: Restrict)

  @@unique([dayId, mealTime, sortOrder])
  @@index([dayId])
  @@index([foodId])
}

model MealPlan {
  id                   String         @id @default(uuid()) @db.Uuid
  sourceMealTemplateId String?        @db.Uuid
  clientId             String         @db.Uuid
  trainerId            String         @db.Uuid
  status               MealPlanStatus @default(DRAFT)
  title                String?
  notes                String?
  startDate            DateTime       @db.Date
  endDate              DateTime       @db.Date
  generatedAt          DateTime       @default(now())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  sourceTemplate MealTemplate? @relation("MealPlanSourceTemplate", fields: [sourceMealTemplateId], references: [id], onDelete: SetNull)

  client  User @relation("MealPlanClient", fields: [clientId], references: [id], onDelete: Cascade)
  trainer User @relation("MealPlanTrainer", fields: [trainerId], references: [id], onDelete: Cascade)

  days MealPlanDay[]

  @@index([sourceMealTemplateId])
  @@index([clientId, status, startDate])
  @@index([trainerId, status, startDate])
  @@index([startDate, endDate])
}

model MealPlanDay {
  id         String   @id @default(uuid()) @db.Uuid
  mealPlanId String   @db.Uuid
  dayIndex   Int
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  mealPlan MealPlan       @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  items    MealPlanItem[]

  @@unique([mealPlanId, dayIndex])
  @@unique([mealPlanId, date])
  @@index([mealPlanId])
  @@index([date])
}

model MealPlanItem {
  id            String   @id @default(uuid()) @db.Uuid
  mealPlanDayId String   @db.Uuid
  foodId        String   @db.Uuid
  portionId     String   @db.Uuid
  quantity      Float    @default(1)
  mealTime      MealTime
  sortOrder     Int      @default(0)

  // Nutrition snapshot at assignment time to keep historical plans immutable.
  foodNameSnapshot     String
  portionLabelSnapshot String
  gramsPerPortion      Float
  baseGramsSnapshot    Float
  caloriesSnapshot     Float
  proteinSnapshot      Float
  carbsSnapshot        Float
  fatSnapshot          Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day     MealPlanDay @relation(fields: [mealPlanDayId], references: [id], onDelete: Cascade)
  food    Food        @relation(fields: [foodId], references: [id], onDelete: Restrict)
  portion FoodPortion @relation(fields: [portionId, foodId], references: [id, foodId], onDelete: Restrict)

  @@unique([mealPlanDayId, mealTime, sortOrder])
  @@index([mealPlanDayId])
  @@index([foodId])
  @@index([mealTime])
}

model ProgressMetric {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @db.Uuid
  metric     ProgressMetricType
  value      Float
  recordedAt DateTime           @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  trainerId String   @db.Uuid
  clientId  String   @db.Uuid
  createdAt DateTime @default(now())

  trainer  User      @relation("ConversationTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  client   User      @relation("ConversationClient", fields: [clientId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([trainerId, clientId])
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @db.Uuid
  senderId       String      @db.Uuid
  body           String
  type           MessageType @default(TEXT)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String            @id @default(uuid()) @db.Uuid
  clientId      String            @db.Uuid
  trainerId     String            @db.Uuid
  grossAmount   Float
  platformFee   Float
  trainerAmount Float
  currency      String
  status        TransactionStatus @default(PENDING)
  createdAt     DateTime          @default(now())

  client  User @relation("TransactionClient", fields: [clientId], references: [id], onDelete: Cascade)
  trainer User @relation("TransactionTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
}

model TrainerWallet {
  trainerId String @id @db.Uuid
  balance   Float  @default(0)

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model Payout {
  id          String       @id @default(uuid()) @db.Uuid
  trainerId   String       @db.Uuid
  amount      Float
  status      PayoutStatus @default(REQUESTED)
  requestedAt DateTime     @default(now())
  paidAt      DateTime?

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiredAt DateTime
}
