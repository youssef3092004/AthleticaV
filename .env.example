# Database Configuration
# Choose ONE of these database connection strings based on your setup
# For local PostgreSQL development:
DATABASE_URL="postgresql://postgres:password@localhost:5432/athleticav_dev"

# For Supabase cloud database:
# SUPABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@db.supabase.co:5432/postgres"

# For Prisma Postgres:
# PRISMA_URL="prisma://db.prisma.io?schema=athleticav"

# Alternative PostgreSQL URLs (used by Prisma config)
# POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/db"
# POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/db"
# POSTGRES_URL="postgresql://user:password@host:5432/db"

# Database Connection Pooling
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Authentication (JWT)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-12345"
JWT_EXPIRES_IN="7d"

# Password Hashing
SALT_ROUNDS=10
MAX_SALT_ROUNDS=12

# Environment
NODE_ENV="development"
PORT=3000

# Rate Limiting & Request Control
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
SLOW_DOWN_AFTER=120

# Frontend & CORS Configuration
FRONTEND_URL="http://localhost:3000,http://localhost:3001"

# Client Application URLs (for invite links and redirects)
CLIENT_APP_URL="http://localhost:3000"
CLIENT_APP_REGISTER_URL="http://localhost:3000/register"
CLIENT_INVITE_LINK_BASE_URL="http://localhost:3000/invite"

# Cache TTL (Time To Live)
CACHE_TTL_MS=30000

# Seeding Configuration
SEED_MEAL_COMPLETION_RATIO=0.4
SEED_MEAL_PLAN_DAYS=7
SEED_MEAL_TEMPLATE_ID="meal-template-id-placeholder"
TEMPLATE_ID="template-id-placeholder"
